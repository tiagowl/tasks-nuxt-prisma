{
  "workflow": {
    "name": "Desenvolvimento Completo",
    "description": "Workflow completo do conceito ao deploy",
    "phases": [
      {
        "phase": "0. Descoberta e Ideação",
        "agents": ["feature-suggester", "product-owner"],
        "duration": "3-5 dias",
        "activities": [
          "Coleta de diretrizes e objetivos",
          "Análise de mercado e tendências",
          "Pesquisa competitiva",
          "Ideação de features inovadoras",
          "Priorização inicial de features",
          "Definição de proposta de valor"
        ],
        "outputs": [
          "feature-suggestions.md",
          "market-analysis.md",
          "competitive-analysis.md",
          "feature-roadmap.md",
          "value-proposition.md",
          "tech-stack-suggestions.md"
        ]
      },
      {
        "phase": "1. Planejamento e Análise",
        "agents": ["product-owner", "ux", "ui-designer", "ddd-architect"],
        "duration": "1-2 semanas",
        "activities": [
          "Análise de requisitos",
          "Pesquisa de usuário",
          "Criação de personas",
          "Definição de user stories",
          "Modelagem de domínio (DDD)",
          "Definição de Bounded Contexts e Linguagem Ubíqua",
          "Wireframes iniciais"
        ],
        "outputs": [
          "requirements.md",
          "user-stories.md",
          "personas.md",
          "bounded-contexts.md",
          "domain-model.md",
          "ubiquitous-language.md",
          "wireframes/"
        ]
      },
      {
        "phase": "2. Arquitetura e Design",
        "agents": ["architect", "ddd-architect", "ux", "ui-designer"],
        "duration": "1 semana",
        "activities": [
          "Design da arquitetura",
          "Refinamento do modelo de domínio",
          "Escolha de tecnologias",
          "Mapeamento contexto-módulo",
          "Prototipação",
          "Design system",
          "Testes de usabilidade"
        ],
        "outputs": [
          "architecture-diagram.md",
          "tech-stack.md",
          "aggregates-and-entities.md",
          "context-map.md",
          "prototypes/",
          "design-system.md"
        ]
      },
      {
        "phase": "3. Desenvolvimento",
        "agents": ["frontend-dev", "backend-dev", "fullstack-dev", "mobile-dev"],
        "duration": "3-4 semanas",
        "activities": [
          "Implementação frontend",
          "Desenvolvimento de APIs",
          "Integração de sistemas",
          "Testes unitários",
          "Code review"
        ],
        "outputs": [
          "frontend-code/",
          "backend-code/",
          "api-documentation.md"
        ]
      },
      {
        "phase": "4. Testes e Qualidade",
        "agents": ["tester", "frontend-dev", "backend-dev", "fullstack-dev", "mobile-dev"],
        "duration": "1-2 semanas",
        "activities": [
          "Testes funcionais",
          "Testes de integração",
          "Testes de performance",
          "Correção de bugs",
          "Validação de requisitos"
        ],
        "outputs": [
          "test-reports/",
          "bug-reports/",
          "performance-reports/"
        ]
      },
      {
        "phase": "5. Deploy e Operação",
        "agents": ["devops", "tester"],
        "duration": "1 semana",
        "activities": [
          "Configuração de ambiente",
          "Deploy automatizado",
          "Monitoramento",
          "Testes de produção",
          "Documentação operacional"
        ],
        "outputs": [
          "deployment-config/",
          "monitoring-setup/",
          "operational-docs/"
        ]
      }
    ],
    "collaboration_matrix": {
      "feature-suggester": ["product-owner", "ux", "architect", "ddd-architect", "ui-designer"],
      "product-owner": ["feature-suggester", "ux", "architect", "ddd-architect", "tester"],
      "ddd-architect": ["product-owner", "feature-suggester", "architect", "backend-dev", "ux"],
      "architect": ["feature-suggester", "ddd-architect", "product-owner", "frontend-dev", "backend-dev", "devops"],
      "ux": ["feature-suggester", "product-owner", "ddd-architect", "frontend-dev"],
      "ui-designer": ["feature-suggester", "ux", "frontend-dev"],
      "frontend-dev": ["ux", "ui-designer", "backend-dev", "tester"],
      "backend-dev": ["architect", "ddd-architect", "frontend-dev", "devops", "tester"],
      "devops": ["architect", "backend-dev", "tester"],
      "tester": ["product-owner", "frontend-dev", "backend-dev", "devops"]
    }
  }
}
