# Banco de Dados Neon (PostgreSQL Serverless)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/task-manager?sslmode=require"

# JWT Secret para autenticação
JWT_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# Credenciais de login (credenciais fixas validadas no servidor)
CREDENTIALS_USERNAME="admin"
CREDENTIALS_PASSWORD="admin123"

# Tempo de sessão em minutos (padrão: 1440 = 24 horas)
NUXT_SESSION_TIMEOUT="1440"
